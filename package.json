{
  "name": "et-xui-e2e-tests",
  "version": "1.0.0",
  "description": "Employment Tribunal E2E Test",
  "main": "index.js",
  "repository": "git@github.com:hmcts/et-xui-e2e-tests.git",
  "author": "sunday.ayeni@hmcts.net",
  "license": "hmcts",
  "private": true,
  "scripts": {
    "pwinstall": "yarn playwright install --with-deps",
    "test:smoke": "yarn pwinstall chromium && yarn playwright test --project=chromium --grep @smoke",
    "test:functional-chromium": "yarn pwinstall chromium && yarn playwright test --project=chromium --grep-invert @accessibility",
    "test:functional-webkit": "yarn pwinstall webkit && yarn playwright test --project=webkit --grep @cx",
    "test:functional-firefox": "yarn pwinstall firefox && yarn playwright test --project=firefox --grep @cx",
    "test:accessibility": "yarn pwinstall && yarn playwright test --project=chromium --grep @accessibility",
    "test:functional-ccd-callback": "yarn pwinstall chromium && yarn playwright test --project=chromium --grep @ccd-callback-tests",
    "test:functional-chromium-demo": "yarn pwinstall chromium && yarn playwright test --project=chromium --grep-invert @accessibility --grep @demo",
    "lint-staged": "lint-staged",
    "lint": "eslint",
    "fortifyScan": "./src/test/java/gradlew -p src/test/java fortifyScan",
    "prepare": "husky install",
    "yarn-update": "yarn set version 4.x",
    "install-dependencies": "/usr/bin/yarn install --silent"
  },
  "lint-staged": {
    "test/**/*.{js,jsx,ts,tsx}": "eslint"
  },
  "dependencies": {
    "@axe-core/playwright": "4.10.2",
    "@faker-js/faker": "10.0.0",
    "axe-html-reporter": "^2.2.11",
    "axios": "1.15.0",
    "chance": "^1.1.11",
    "dotenv": "^17.2.3",
    "eslint": "9.35.0",
    "fs-extra": "^11.3.3",
    "lint-staged": "16.1.6",
    "lodash": "^4.17.23",
    "proper-lockfile": "^4.1.2",
    "totp-generator": "2.0.0",
    "typescript-logging": "^2.2.0",
    "typescript-logging-log4ts-style": "^2.2.0"
  },
  "devDependencies": {
    "@faker-js/faker": "10.0.0",
    "@hmcts/playwright-common": "^1.0.36",
    "@playwright/test": "^1.50.1",
    "@types/fs-extra": "^11",
    "@types/lodash": "^4",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4",
    "husky": "9.1.7"
  },
  "resolutions": {
    "axios": "1.15.0",
    "braces": "^3.0.3",
    "cross-spawn": "^7.0.5",
    "express": "^5.0.0",
    "got": "^11.8.5",
    "log4js": "^6.4.0",
    "semver-regex": "^3.1.4",
    "tough-cookie": "^6.0.0",
    "ws": "^8.17.1",
    "glob": "11.1.0",
    "js-yaml": "4.1.1",
    "brace-expansion": "^4.0.1",
    "formdata-node": "6.0.3"
  },
  "packageManager": "yarn@4.9.4"
}
